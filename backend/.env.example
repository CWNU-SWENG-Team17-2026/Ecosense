# App
APP_NAME=EcoSense API
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (SQLite for local dev, MariaDB for production)
DATABASE_URL=sqlite:///./ecosense.db
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/ecosense

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Outdoor API (optional - mock data used when empty)
KMA_API_KEY=
AIRKOREA_API_KEY=
OUTDOOR_CACHE_TTL_MINUTES=30

# Cookie 보안 (배포 시 HTTPS 환경에서 반드시 true로 변경)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# 배포 시 DEBUG=false, SECRET_KEY를 32자 이상 랜덤 문자열로 반드시 변경
# python -c "import secrets; print(secrets.token_hex(32))"
