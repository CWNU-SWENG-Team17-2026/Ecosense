# App
APP_NAME=EcoSense API
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (SQLite for local dev, MariaDB for production)
DATABASE_URL=sqlite:///./ecosense.db
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/ecosense

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Outdoor API
# KMA_API_KEY: 기상청 API허브 authKey (ASOS 시간관측) — https://apihub.kma.go.kr
# KMA_FORECAST_SERVICE_KEY: 공공데이터포털 단기예보 serviceKey (초단기실황, 날씨앱과 유사)
#   → data.go.kr 에서 "단기예보 조회서비스" 별도 신청 필요
# AIRKOREA_API_KEY: 공공데이터포털 에어코리아 serviceKey — 대기질(PM2.5/PM10)
KMA_API_KEY=
KMA_FORECAST_SERVICE_KEY=
AIRKOREA_API_KEY=
OUTDOOR_CACHE_TTL_MINUTES=10

# Cookie 보안 (배포 시 HTTPS 환경에서 반드시 true로 변경)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# 배포 시 DEBUG=false, SECRET_KEY를 32자 이상 랜덤 문자열로 반드시 변경
# python -c "import secrets; print(secrets.token_hex(32))"
