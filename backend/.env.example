# App
APP_NAME=EcoSense API
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# 로컬: sqlite 또는 mysql+pymysql://...
# Render: postgresql+psycopg2://USER:PASS@HOST:5432/DB
DATABASE_URL=sqlite:///./ecosense.db

# CORS — Render Environment에 반드시 설정 (main.py 하드코딩 금지)
# CORS_ORIGINS=https://ecosense-sooty.vercel.app,http://localhost:5173
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Outdoor API
KMA_API_KEY=
KMA_FORECAST_SERVICE_KEY=
AIRKOREA_API_KEY=
OUTDOOR_CACHE_TTL_MINUTES=10

# Brevo 이메일 인증 (https://app.brevo.com → SMTP & API → API Keys)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@yourdomain.com

# 스키마 재생성 (실데이터 없을 때 1회만 true → 배포 후 false로 되돌리기)
RESET_DB_ON_STARTUP=false

# Cookie (Vercel + Render cross-site 배포)
# DEBUG=false, COOKIE_SECURE=true, COOKIE_SAMESITE=none
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# 배포 시 DEBUG=false, SECRET_KEY를 32자 이상 랜덤 문자열로 반드시 변경
# python -c "import secrets; print(secrets.token_hex(32))"
